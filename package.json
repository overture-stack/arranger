{
	"$schema": "https://json.schemastore.org/package.json",
	"devDependencies": {
		"@eslint/js": "^9.18.0",
		"@tsconfig/node22": "^22.0.0",
		"@types/node": "^22.13.10",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"ajv": "^8.18.0",
		"concurrently": "^9.1.2",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-import-resolver-typescript": "^3.7.0",
		"eslint-plugin-file-extension-in-import-ts": "^2.1.1",
		"eslint-plugin-import": "^2.31.0",
		"globals": "^15.14.0",
		"prettier": "^3.5.3",
		"prettier-plugin-organize-imports": "^4.1.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"turbo": "^2.9.12",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.26.1"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/overture-stack/arranger.git"
	},
	"scripts": {
		"clear:nodeModules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
		"components:watch": "npm run watch -w modules/components",
		"dev:components": "concurrently -n types,router,server -c magenta,blue,green \"npm run types:watch\" \"npm run components:watch\"",
		"dev:check": "npm run test:dev",
		"dev:server": "concurrently --raw -n sqon,types,router,server -c yellow,magenta,blue,green --hide sqon,types,router \"npm run sqon:watch\" \"npm run types:watch\" \"npm run graphql-router:watch\" \"npm run server:dev\"",
		"graphql-router:build": "npm run build -w modules/graphql-router",
		"graphql-router:watch": "npm run watch -w modules/graphql-router",
		"install:memory-safe": "npm i --ignore-scripts && npm rebuild --foreground-scripts --workspaces --loglevel=warn",
		"mcp-server": "npm run start --w apps/mcp-server",
		"mcp-server:dev": "npm run dev --w apps/mcp-server",
		"mcp-server:inspect": "npm run inspect --w apps/mcp-server",
		"modules:build": "npm run build --w modules",
		"modules:tag": "npm version --ws --force-publish --yes",
		"modules:watch": "npm run watch -w modules",
		"publish::ci": "npm publish --ws --if-present",
		"release:check": "node scripts/verify-pack.mjs",
		"sqon:build": "npm run build -w modules/sqon",
		"sqon:watch": "npm run watch -w modules/sqon",
		"reset": "npm run clear:nodeModules && npm run clear:dist --ws --if-present",
		"server": "npm run start -w apps/search-server",
		"server:dev": "npm run dev -w apps/search-server",
		"test": "npm run test --ws --if-present",
		"test:dev": "npm run test -w modules/sqon -w modules/types -w modules/graphql-router -w apps/search-server -w integration-tests/import",
		"test:watch": "concurrently --group \"npm:modules:watch\" --group \"npm:test:watch -w modules/components -w integration-tests/import\"",
		"turbo:build": "npx turbo run build",
		"turbo:test": "npx turbo run test",
		"types:build": "npm run build -w modules/types",
		"types:watch": "npm run watch -w modules/types"
	},
	"overrides": {
		"@types/express": "4.17.25",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"ajv-draft-04": {
			"ajv": "^8.18.0"
		},
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"type": "module",
	"workspaces": [
		"apps/search-server",
		"apps/mcp-server",
		"integration-tests/import",
		"integration-tests/mcp-server",
		"integration-tests/server",
		"modules/charts",
		"modules/components",
		"modules/graphql-router",
		"modules/sqon",
		"modules/types"
	]
}
