{
	"name": "@overture-stack/arranger-types",
	"description": "Shared Arranger config constants and TypeScript types",
	"version": "0.0.0-dev",
	"homepage": "https://github.com/overture-stack/arranger#readme",
	"bugs": {
		"url": "https://github.com/overture-stack/arranger/issues"
	},
	"repository": {
		"directory": "modules/types",
		"type": "git",
		"url": "git+https://github.com/overture-stack/arranger.git"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./configs": {
			"types": "./dist/configs/index.d.ts",
			"default": "./dist/configs/index.js"
		},
		"./configs/constants": {
			"types": "./dist/configs/constants.d.ts",
			"default": "./dist/configs/constants.js"
		},
		"./elastic": {
			"types": "./dist/elastic/index.d.ts",
			"default": "./dist/elastic/index.js"
		},
		"./elastic/constants": {
			"types": "./dist/elastic/constants.d.ts",
			"default": "./dist/elastic/constants.js"
		},
		"./tools": {
			"types": "./dist/tools/index.d.ts",
			"default": "./dist/tools/index.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.release.json",
		"clear:dist": "rm -rf dist",
		"patchTS": "ts-patch install -s",
		"prepare": "npm run patchTS",
		"test": "tsx --test",
		"test:watch": "npm test -- --watch",
		"watch": "nodemon -w src -w ../sqon/dist -e ts --exec \"npm run build\""
	},
	"dependencies": {
		"@overture-stack/sqon": "file:../sqon"
	},
	"devDependencies": {
		"@tsconfig/node22": "^22.0.0",
		"@types/node": "^22.19.13",
		"nodemon": "^3.1.9",
		"tsx": "^4.19.2",
		"typescript": "^5.8.2",
		"typescript-transform-paths": "^3.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module"
}
